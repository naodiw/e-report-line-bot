{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@ereport/core": ["packages/core/src/index.ts"],
      "@ereport/logging": ["packages/logging/src/index.ts"],
      "@ereport/connectors": ["packages/connectors/src/index.ts"],
      "@ereport/sheets": ["packages/sheets/src/index.ts"]
    }
  }
}
